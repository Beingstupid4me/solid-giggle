{
  "button": {
    "primary": {
      "radius": "pill",
      "background": "color.primary",
      "backgroundHover": "color.primaryDark",
      "text": "color.surfaceLight",
      "fontWeight": "font.weight.bold",
      "shadow": "shadow.brand"
    },
    "outline": {
      "radius": "pill",
      "border": "color.primary",
      "text": "color.primary",
      "backgroundHover": "color.primary",
      "textHover": "color.surfaceLight"
    },
    "ghost": {
